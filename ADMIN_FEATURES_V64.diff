+    doc = {
+        "id": str(uuid.uuid4()),
+        "title": title,
+        "description": body.description.strip(),
+        "icon": body.icon.strip() or "trophy",
+        "color": body.color.strip() or "#FFB800",
+        "active": body.active,
+        "created_by": admin["id"],
+        "created_at": now_iso(),
+    }
+    await db.achievements.insert_one(doc)
+    return {k: v for k, v in doc.items() if k != "_id"}
